# 米游社自动签到 - 环境变量配置
# 复制此文件为 .env 并修改以下值

# JWT 签名密钥（必须修改为强随机字符串）
SECRET_KEY=your_secret_key_here_change_me

# Cookie AES 加密密钥（必须修改为强随机字符串，并在后续部署中长期保持不变）
# 如果每次重启都换新值，历史 Cookie / 历史敏感密文会因为无法解密而全部失效
ENCRYPTION_KEY=your_encryption_key_here_change_me

# MySQL 8 配置（生产部署建议显式填写）
MYSQL_DATABASE=miyoushe
MYSQL_USER=miyoushe
MYSQL_PASSWORD=change_me_mysql_password
MYSQL_ROOT_PASSWORD=change_me_mysql_root_password

# 本机直接运行后端时，可按本地 MySQL 地址填写：
# DATABASE_URL=mysql+asyncmy://miyoushe:change_me_mysql_password@127.0.0.1:3306/miyoushe?charset=utf8mb4
#
# Docker Compose 部署时通常不要在 .env 里额外写 DATABASE_URL，
# 让 docker-compose.yml 使用容器内的 `@mysql:3306` 默认值即可。

# SMTP 邮件配置（可选，不填则不发送邮件通知）
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=noreply@example.com
SMTP_PASSWORD=your_smtp_password
SMTP_USE_SSL=true
