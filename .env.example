# 米游社自动签到 - 环境变量配置
# 复制此文件为 .env 并修改以下值

# JWT 签名密钥（必须修改为强随机字符串）
SECRET_KEY=your_secret_key_here_change_me

# Cookie AES 加密密钥（必须修改为强随机字符串）
ENCRYPTION_KEY=your_encryption_key_here_change_me

# SMTP 邮件配置（可选，不填则不发送邮件通知）
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=noreply@example.com
SMTP_PASSWORD=your_smtp_password
SMTP_USE_SSL=true
